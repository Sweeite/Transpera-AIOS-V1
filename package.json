{
  "name": "aios",
  "version": "0.0.0",
  "private": true,
  "description": "AIOS — a durable, queryable, permission-safe organisational brain. Sealed shared core + per-client plugins. See AIOS_Brief.md.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:packages": "pnpm -r test",
    "test:core": "vitest run tests/core",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "ask:sop": "tsx scripts/answer.ts",
    "lint": "pnpm -r lint",
    "dev:api": "pnpm --filter @aios/api dev",
    "dev:worker": "pnpm --filter @aios/worker dev",
    "provision": "pnpm --filter @aios/control-plane provision",
    "migrate:all": "pnpm --filter @aios/control-plane migrate-all",
    "deploy:all": "pnpm --filter @aios/control-plane deploy-all"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@types/node": "^20",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^4.4.3"
  }
}
