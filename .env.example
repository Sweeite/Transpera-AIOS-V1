# AIOS environment — copy to `.env` (gitignored) and fill in. One tenant per process (§8.2).

# ── Tenant + DB connection (#7) ────────────────────────────────────────────────────────────────────
# The engine refuses to boot without TENANT_ID (fail-closed). No cross-tenant query path.
TENANT_ID=

# API/engine → Supavisor TRANSACTION mode. The client opens this with prepare:false (pooled, stateless).
DATABASE_URL=

# Worker + crons → SESSION/direct mode. pgmq, LISTEN/NOTIFY, and advisory locks BREAK under transaction
# pooling, so the worker MUST use this separate URL (#7 Watch).
DATABASE_URL_SESSION=

# ── Local test lanes ───────────────────────────────────────────────────────────────────────────────
# Set to run the real-Supabase migration lane locally (else it self-skips). From `supabase start`:
#   postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_DB_URL=

# ── Embedding / model providers (#1) ───────────────────────────────────────────────────────────────
# BYO vendor keys. NEVER commit real keys (.env is gitignored).
OPENAI_API_KEY=
VOYAGE_API_KEY=
ANTHROPIC_API_KEY=
