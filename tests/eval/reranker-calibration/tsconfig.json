{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ES2023"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "composite": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["*.ts"]
}
