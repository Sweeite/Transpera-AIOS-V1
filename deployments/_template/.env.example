# AIOS per-client deployment env. ZERO logic lives here — config only (Brief §8.2).
# One filled-in copy exists per client, holding only that client's connection + keys.

# --- Tenant identity (drives plugin loading at boot, Brief §8.2) ---
TENANT_ID=acme

# --- Data plane: the client's OWN Supabase project (Brief §8.1a) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=                 # pooled (Supavisor) connection string for the engine + worker

# --- LLM: per-client BYO keys (Brief §12, tech-stack §5.4) — no shared org key ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=               # optional, multi-provider routing
EMBEDDING_API_KEY=            # the single pinned embedding model's provider
RERANKER_API_KEY=             # optional until the reranker floor is built

# --- Queue: pgmq lives INSIDE the client's Supabase (no shared Redis, tech-stack §5.4) ---
PGMQ_SCHEMA=pgmq

# --- Secrets: client SoR credentials live in the client's Supabase Vault, NOT here ---
# (per-user OAuth tokens, CRM/accounting keys) — see tech-stack §5.4.

# --- Observability ---
SENTRY_DSN=                   # fleet alerting, day one (tech-stack §5.4)
LATENCY_BUDGET_MS=8000        # per-turn budget; federation fetches carry a deadline (Brief §12)

# --- Cold-start (Brief §10.3) ---
COLDSTART_BACKFILL_DAYS=90
COLDSTART_MODE=true
